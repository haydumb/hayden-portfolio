---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import SkillsMatrix from '../components/SkillsMatrix.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import Contact from '../components/Contact.astro';
import Terminal from '../components/Terminal.tsx';
import MetricsStrip from '../components/MetricsStrip.tsx';
import { getCollection } from 'astro:content';
import { site } from '../data/site';

const work = (await getCollection('work'))
  .sort((a, b) => a.data.order - b.data.order)
  .map((w) => ({ slug: w.id, title: w.data.title }));
---
<BaseLayout>
  <section class="py-12">
    <p class="font-mono text-xs uppercase tracking-widest text-[var(--color-green)]">{site.role}</p>
    <h1 class="mt-2 font-mono text-3xl font-extrabold text-[var(--color-text)] sm:text-4xl">{site.tagline}</h1>
    <p class="mt-3 max-w-2xl text-[var(--color-muted)]">{site.summary}</p>
    <div class="mt-8">
      <Terminal client:load work={work} />
    </div>
  </section>

  <div class="border-y border-[var(--color-border)] py-8">
    <MetricsStrip client:visible />
  </div>

  <Section id="about" title="whoami">
    <p class="max-w-2xl text-[var(--color-text)]/90">
      I'm Hayden, a DevOps and platform engineer based in {site.location}. For about seven years
      I've automated CI/CD, run cloud infrastructure, and written the tooling that keeps deployments
      fast and boring. Lately I've been building AI tooling on top of that, like MCP servers and
      custom Claude plugins, to automate work people used to do by hand.
    </p>
  </Section>

  <Section id="skills" title="skills"><SkillsMatrix /></Section>
  <Section id="experience" title="experience"><ExperienceTimeline /></Section>
  <Section id="contact" title="contact"><Contact /></Section>
</BaseLayout>
